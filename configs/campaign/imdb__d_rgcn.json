{
  "dataset": "imdb",
  "use_topology": false,
  "fusion": "attention",
  "seed": 0,
  "base_relations": {
    "MDM": [
      [
        "movie",
        "to",
        "director"
      ],
      [
        "director",
        "to",
        "movie"
      ]
    ],
    "MAM": [
      [
        "movie",
        ">actorh",
        "actor"
      ],
      [
        "actor",
        "to",
        "movie"
      ]
    ],
    "MKM": [
      [
        "movie",
        "to",
        "keyword"
      ],
      [
        "keyword",
        "to",
        "movie"
      ]
    ]
  },
  "han_metapaths": [
    "MDM",
    "MAM"
